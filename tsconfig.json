{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Environment Settings */
    "target": "ES2020",              // modern JS but supported by Node
    "module": "CommonJS",            // Node.js default (or "NodeNext" if you want ESM)
    "lib": ["ES2020"],               // include latest JS features
    "types": ["node"],               // include Node.js typings

    /* Other Outputs */
    "sourceMap": true,
    "declaration": true,

    /* Stricter Typechecking */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    /* Module Resolution */
    "esModuleInterop": true,         // allow `import express from "express"`
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
